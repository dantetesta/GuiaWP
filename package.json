{
  "name": "guiawp",
  "version": "1.7.2",
  "private": true,
  "description": "Build assets para o plugin GuiaWP",
  "author": "Dante Testa <https://dantetesta.com.br>",
  "scripts": {
    "build:css": "npx tailwindcss -i ./assets/css/tailwind-input.css -o ./assets/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i ./assets/css/tailwind-input.css -o ./assets/css/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4",
    "@tailwindcss/forms": "^0.5",
    "@tailwindcss/container-queries": "^0.1"
  }
}
